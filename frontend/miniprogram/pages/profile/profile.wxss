/** pages/profile/profile.wxss **/
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.profile-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 60rpx 30rpx 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
  color: white;
}

.avatar {
  font-size: 80rpx;
  display: block;
  margin: 0 auto 20rpx;
}

.username {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.user-info {
  font-size: 24rpx;
  opacity: 0.9;
  display: block;
}

.profile-content {
  background: white;
  border-radius: 15rpx;
  overflow: hidden;
  box-shadow: 0 5rpx 15rpx rgba(0,0,0,0.08);
}

.section {
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.section:last-child {
  border-bottom: none;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.promotion-item {
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.promotion-item:last-child {
  border-bottom: none;
}

.promotion-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 5rpx;
}

.promotion-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.favorite-item {
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.favorite-item:last-child {
  border-bottom: none;
}

.favorite-title {
  font-size: 28rpx;
  color: #333;
  display: block;
}