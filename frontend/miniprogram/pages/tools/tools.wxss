/** pages/tools/tools.wxss **/
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 30rpx 0;
  background: white;
  margin-bottom: 20rpx;
  border-radius: 15rpx;
  box-shadow: 0 5rpx 15rpx rgba(0,0,0,0.08);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.tools-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.tool-item {
  background: white;
  padding: 30rpx;
  border-radius: 15rpx;
  text-align: center;
  box-shadow: 0 5rpx 15rpx rgba(0,0,0,0.08);
}

.tool-icon {
  font-size: 48rpx;
  margin-bottom: 20rpx;
}

.tool-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.tool-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}