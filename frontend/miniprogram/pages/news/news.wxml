<!--pages/news/news.wxml-->
<view class="container">
  <view class="header">
    <text class="title">新能源资讯</text>
  </view>
  
  <view class="category-tabs">
    <view class="tab-item active">最新资讯</view>
    <view class="tab-item">政策动态</view>
    <view class="tab-item">技术前沿</view>
    <view class="tab-item">市场分析</view>
  </view>
  
  <view class="news-list">
    <view class="news-item" wx:for="{{newsList}}" wx:key="id" bindtap="viewNewsDetail" data-id="{{item.id}}">
      <text class="news-title">{{item.title}}</text>
      <view class="news-meta">
        <text class="news-source">{{item.source}}</text>
        <text class="news-date">{{item.date}}</text>
      </view>
    </view>
  </view>
</view>